# Supabase — copy to .env.local (gitignored) and fill from the project's API settings.
PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# Server-only. Never commit. Used by src/lib/db/service.ts for admin paths.
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Anthropic (M7). Leave unset until then.
ANTHROPIC_API_KEY=
